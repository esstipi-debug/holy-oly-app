// Holy Oly API — Prisma schema (Postgres).
// Multi-tenant from the first migration: Coach + Vinculo gate every coach-scoped read.
// The macrocycle catalog stays in @holy-oly/core (static reference data) — not a table.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Nivel {
  beginner
  intermediate
  advanced
  elite
}

enum VinculoEstado {
  pendiente
  activo
  rechazado
  revocado
}

enum CycleShare {
  full
  min
  none
}

enum CycleState {
  regular
  unreliable
  amenorrhea
}

enum Metal {
  oro
  plata
  bronce
}

enum CompRole {
  pico
  paso
}

enum SessionStatus {
  done
  missed
}

enum UserRole {
  coach
  atleta
}

enum SubscriptionStatus {
  none
  active
  past_due
  canceled
}

/// Auth identity (login) for both coaches and athletes — email/password (argon2) and/or OAuth.
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String?
  role         UserRole
  emailVerified Boolean  @default(false)
  createdAt    DateTime  @default(now())
  // Legal acceptance trail (PR-L1): timestamp + document version the account accepted at signup.
  // The server stamps the version (core constants) — never trusts a client-sent version.
  termsAcceptedAt   DateTime?
  termsVersion      String?
  privacyAcceptedAt DateTime?
  privacyVersion    String?
  sessions     Session[]
  coach        Coach?
  athlete      Athlete?
  oauthAccounts          OAuthAccount[]
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]
}

/// External login provider linked to a User (Google, etc.).
model OAuthAccount {
  id             String   @id @default(cuid())
  provider       String
  providerUserId String
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@unique([provider, providerUserId])
  @@index([userId])
}

/// Server-side, revocable session. `id` is the SHA-256 (hex) of the token held in the
/// httpOnly cookie — the raw token is never stored.
model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime

  @@index([userId])
  @@index([expiresAt]) // D5: cheap cleanup of expired sessions (DELETE WHERE expiresAt < now)
}

/// Append-only security/audit event (A9). No FK relations on purpose: the trail must survive
/// actor/target deletion, and it stores NO secrets (no password/token/email/cycle-state) — only
/// ids + a short action label + source ip + timestamp.
model AuditEvent {
  id              String    @id @default(uuid())
  ts              DateTime  @default(now())
  action          String
  actorUserId     String?
  actorRole       UserRole?
  targetAthleteId String?
  ip              String?

  @@index([ts])
  @@index([actorUserId])
}

/// The paying tenant. A Coach is a User (role=coach) + this profile + a rotatable invite code.
model Coach {
  id         String    @id @default(uuid())
  userId     String    @unique
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  inviteCode String?   @unique
  createdAt  DateTime  @default(now())
  vinculos   Vinculo[]
  subscription Subscription?
  competitions Competition[]
}

/// B2B coach subscription (E3–E5). Athletes are free; only coaches pay.
model Subscription {
  id                 String             @id @default(cuid())
  coachId            String             @unique
  coach              Coach              @relation(fields: [coachId], references: [id], onDelete: Cascade)
  provider           String             @default("mock")
  providerCustomerId String?
  providerSubId      String?
  planId             String?
  status             SubscriptionStatus @default(none)
  currentPeriodEnd   DateTime?
  updatedAt          DateTime           @updatedAt
}

/// Idempotent billing webhook processing (E3).
model WebhookEvent {
  id          String   @id
  provider    String
  processedAt DateTime @default(now())
}

/// Single-use password reset token (B6). `id` = SHA-256(raw token) hex — raw token never stored.
model PasswordResetToken {
  id        String    @id
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// Single-use email verification token (B6b).
model EmailVerificationToken {
  id        String    @id
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// Athlete. Ownership is modeled through Vinculo (not a direct coachId) so athletes
/// can be linked to a coach via the invite flow and own their own data.
model Athlete {
  id           String        @id @default(uuid())
  userId       String?       @unique
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  nombre       String
  iniciales    String
  nivel        Nivel
  macroId      String?
  compite      Boolean       @default(false)
  sexo         String        @default("M")
  weightBandLo Float?
  weightBandHi Float?
  createdAt    DateTime      @default(now())
  vinculos     Vinculo[]
  plan         Plan?
  comps        Competencia[]
  weeks        MonitorWeek[]
  medals       Medal[]
  sessions     SessionMark[]
  cycle        CycleConsent?
  dayLogs      DayLog[]
  prescription PrescribedExercise[]
  actuals          SessionActual[]
  rmUpdates        RmUpdate[]
  sessionRegistros SessionRegistro[]
  macroHistory     MacroHistory[]
  competitionEntries CompetitionEntry[]
}

/// The multi-tenancy join: a coach sees an athlete only via an `activo` Vinculo.
model Vinculo {
  id         String        @id @default(uuid())
  coachId    String
  coach      Coach         @relation(fields: [coachId], references: [id], onDelete: Cascade)
  athleteId  String
  athlete    Athlete       @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  estado     VinculoEstado @default(pendiente)
  inviteCode String?
  createdAt  DateTime      @default(now())

  @@unique([coachId, athleteId])
  @@index([coachId, estado])
}

model Plan {
  id        String  @id @default(uuid())
  athleteId String  @unique
  athlete   Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  macroId   String
  startWeek Int
  startDate String? // ISO YYYY-MM-DD — the plan's calendar anchor (set at assignment, M5)
  rms       Json
}

/// Athlete-scoped competitions (mirrors getComps/setComps).
model Competencia {
  id        String  @id @default(uuid())
  athleteId String
  athlete   Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  name      String
  week      Int
  date      String? // ISO YYYY-MM-DD the coach picked; week is derived from it
  // Slice competencias (2026-06-14): id de la compe COMPARTIDA que sincronizó esta fila (rol
  // "pico"). Null = fila creada a mano (legacy / CompSheet directo). Sin FK formal: el sync la
  // matchea por este id (ver repo competitions). Aditivo + nullable → filas viejas quedan en null.
  competitionId String?

  @@index([athleteId])
  @@index([competitionId])
}

/// Coach-tracked session adherence (mirrors getSessionLog/setSessionLog). Sparse — only marked
/// sessions stored (unmarked = pending). `idx` is the session's position within its week.
model SessionMark {
  id        String        @id @default(uuid())
  athleteId String
  athlete   Athlete       @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  week      Int
  idx       Int
  status    SessionStatus

  @@unique([athleteId, week, idx])
  @@index([athleteId])
}

/// Fecha REAL del entreno por sesión registrada (spec 2026-06-12 D1/D3). Fuente de verdad;
/// SessionActual.doneAt es copia estampada en la misma transacción (jamás divergen). La regla
/// 1×fecha NO es unique de DB (la excepción AM/PM la rompe): vive en setSessionActuals.
model SessionRegistro {
  id         String  @id @default(uuid())
  athleteId  String
  athlete    Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  week       Int
  sessionIdx Int
  fecha      String
  /// Secuencia de días (2026-06-13): 'hecho' (default) | 'anulado' (día saltado, sin volumen).
  estado     String  @default("hecho")

  @@unique([athleteId, week, sessionIdx])
  @@index([athleteId, fecha])
}

/// One row per athlete-week. `recovery` is computed via core.recoverySeries on write.
model MonitorWeek {
  id         String         @id @default(uuid())
  athleteId  String
  athlete    Athlete        @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  week       Int
  acute      Float
  hrv        Float
  hrvBase    Float
  rhr        Float
  rhrBase    Float
  imr        Float
  wellness   Float
  recovery   Float
  compliance Float?
  rpe        Float?
  bodyweight Float?
  items      WellnessItem[]

  @@unique([athleteId, week])
}

/// Normalizes MonitorSeries.wellnessItems (Record<string, number[]>) into per-(week,item) rows.
model WellnessItem {
  id            String      @id @default(uuid())
  monitorWeekId String
  monitorWeek   MonitorWeek @relation(fields: [monitorWeekId], references: [id], onDelete: Cascade)
  key           String
  value         Int

  @@unique([monitorWeekId, key])
}

/// One athlete-day self-report (Proyecto A). Private to the athlete; one row per (athlete, date).
model DayLog {
  id         String  @id @default(uuid())
  athleteId  String
  athlete    Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  date       String  // ISO YYYY-MM-DD
  fatiga     Int
  dolor      Int
  estres     Int
  humor      Int
  motivacion Int
  sueno      Int
  weight     Float?

  @@unique([athleteId, date])
  @@index([athleteId])
}

model Medal {
  id        String  @id @default(uuid())
  athleteId String
  athlete   Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  comp      String
  date      String
  cat       String
  medal     Metal
  sn        Int
  cj        Int
  place     String
  // Slice competencias (2026-06-14, Fase 2): id de la compe compartida cuando el resultado se
  // cargó desde una compe gestionada. Null = medalla cargada a mano (texto libre). Aditivo.
  competitionId String?

  @@index([athleteId])
}

/// Athlete-private cycle consent. The coach NEVER reads this directly — only the
/// server-computed, redacted CycleContext is exposed (no raw share/state to a coach).
model CycleConsent {
  athleteId String  @id
  athlete   Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  // D1: stored encrypted-at-rest (AES-256-GCM) when CYCLE_ENCRYPTION_KEY is set; values are the
  // CycleShare/CycleState string unions (validated app-side). TEXT to hold ciphertext or plaintext.
  share     String
  state     String
  /// Slice ciclo-visible: registro de la atleta — cifrados at-rest igual que share/state.
  lastPeriodStart String?
  cycleLengthDays String?
  /// PR-L2: acto de consentimiento informado (opt-in explícito). `consentedAt == null` → la
  /// atleta aún no activó el módulo (la UI muestra el gate de activación, no el registro).
  /// No se cifran: son metadata de consentimiento (no dato de salud) y deben poder auditarse.
  consentedAt    DateTime?
  consentVersion String?
}

/// What the athlete actually lifted, per prescribed exercise (SP3). Self-written (requireAthlete).
model SessionActual {
  id          String   @id @default(uuid())
  athleteId   String
  athlete     Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  week        Int
  sessionIdx  Int
  order       Int
  movementId           String
  prescribedMovementId String?
  done        Boolean  @default(true)
  actualKg    Float?
  actualReps  Int?
  note        String?
  doneAt      String?
  sets        Json?

  @@unique([athleteId, week, sessionIdx, order])
  @@index([athleteId, week])
}

/// One prescribed exercise of an athlete's plan (SP2). Coach-owned; the athlete is read-only.
model PrescribedExercise {
  id          String   @id @default(uuid())
  athleteId   String
  athlete     Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  week        Int
  sessionIdx  Int
  order       Int
  movementId  String
  sets        Int
  reps        Int
  pct         Float?
  kgOverride  Float?
  flags       String[]
  notes       String?

  @@unique([athleteId, week, sessionIdx, order])
  @@index([athleteId, week])
}

/// Historial de macrociclos CERRADOS (slice macro-history 2026-06-14). `Plan` es 1:1 = el ciclo en
/// curso; esta tabla guarda los ciclos completados con su adherencia (sesiones hechas/prescritas)
/// y el snapshot de RM al cerrar. La adherencia % se DERIVA al leer (core macroHistoryView), nunca
/// se almacena. `ordinal` ascendente (1 = el más antiguo); único por atleta para reseed idempotente.
model MacroHistory {
  id            String   @id @default(uuid())
  athleteId     String
  athlete       Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  macroId       String
  ordinal       Int
  startDate     String   // ISO YYYY-MM-DD
  endDate       String   // ISO YYYY-MM-DD
  weeks         Int
  sessionsDone  Int
  sessionsTotal Int
  rmEnd         Json?    // { arranque, envion, sentadilla, frente } al cerrar el ciclo
  createdAt     DateTime @default(now())

  @@unique([athleteId, ordinal])
  @@index([athleteId])
}

/// Historial append-only de RMs (SP5). Cada cambio de Plan.rms escribe una fila acá (mismo
/// valor) — la última por lift coincide con Plan.rms. `reason`: assign (baseline al asignar) |
/// manual (edición del coach) | pr (confirmación de un PR). `setAt` ISO YYYY-MM-DD.
model RmUpdate {
  id        String   @id @default(uuid())
  athleteId String
  athlete   Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  lift      String
  kg        Float
  setAt     String
  reason    String
  createdAt DateTime @default(now())

  @@index([athleteId])
}

/// Competencia COMPARTIDA, propiedad del coach (slice competencias 2026-06-14). El coach la crea
/// UNA vez y acopla a varios atletas de su plantel (vínculo activo) vía CompetitionEntry. Catálogo
/// por-coach: si dos coaches van al mismo torneo, son dos filas (sin catálogo global / sin dedup).
model Competition {
  id        String             @id @default(uuid())
  coachId   String
  coach     Coach              @relation(fields: [coachId], references: [id], onDelete: Cascade)
  name      String
  date      String             // ISO YYYY-MM-DD
  place     String?
  createdAt DateTime           @default(now())
  entries   CompetitionEntry[]

  @@index([coachId])
}

/// El ACOPLE atleta ↔ competencia. `role` = pico (ancla el macro) | paso (no toca el plan). Los
/// campos de resultado (medal/cat/sn/cj/place) son opcionales y se llenan DESPUÉS de la compe
/// (Fase 2). Único por (competitionId, athleteId): un atleta una vez por compe.
model CompetitionEntry {
  id            String      @id @default(uuid())
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  athleteId     String
  athlete       Athlete     @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  role          CompRole
  medal         Metal?
  cat           String?
  sn            Int?
  cj            Int?
  place         String?
  createdAt     DateTime    @default(now())

  @@unique([competitionId, athleteId])
  @@index([competitionId])
  @@index([athleteId])
}
