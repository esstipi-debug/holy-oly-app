# Copy to apps/api/.env and adjust. Matches docker-compose.yml (port 5433).
DATABASE_URL="postgresql://holyoly:holyoly@localhost:5433/holyoly_dev?schema=public"
TEST_DATABASE_URL="postgresql://holyoly:holyoly@localhost:5433/holyoly_test?schema=public"

# Dev-only stub coach (Fase 1). Replaced by real session auth in Fase 3.
DEV_COACH_ID="coach-stub"

# Public URL of the web app (password-reset and email-verify links). Local demo: http://localhost:8765
APP_ORIGIN="http://localhost:8765"

# API public URL for OAuth callbacks when web and API are on different origins.
# Defaults to APP_ORIGIN when SERVE_WEB=true (same origin). Split deploy: e.g. http://localhost:3000
# API_ORIGIN="http://localhost:3000"

# Google OAuth (optional). Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match: ${API_ORIGIN or APP_ORIGIN}/auth/google/callback
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_OAUTH_STATE_SECRET=""  # optional; defaults to GOOGLE_CLIENT_SECRET

# Email (B0). Default "console" logs to stdout in dev. Production: set EMAIL_PROVIDER=resend|postmark|ses + API key (when adapter exists).
EMAIL_PROVIDER="console"

# Billing (E3–E5). Default "mock" for dev/demo. Production Chile: mercadopago + server-side keys.
BILLING_PROVIDER="mock"
BILLING_WEBHOOK_SECRET="dev-mock-webhook-secret"

# Mercado Pago Chile (when BILLING_PROVIDER=mercadopago). Create preapproval_plan per tier in MP dashboard.
# MERCADOPAGO_ACCESS_TOKEN=""
# MERCADOPAGO_WEBHOOK_SECRET=""
# MERCADOPAGO_PLAN_BASICO=""
# MERCADOPAGO_PLAN_EQUIPO=""

# Coach write gating: active subscription required (402). Off in tests unless BILLING_ENFORCE=true.
# Default on in dev/prod; set BILLING_ENFORCE=false to disable locally.
# BILLING_ENFORCE="false"

# Coach must verify email before confirming vínculos. Default on in dev/prod.
# EMAIL_VERIFY_ENFORCE="false"
