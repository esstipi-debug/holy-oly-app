      '<div class="phase__row"><span>'+L(lang,'lbl_vol')+'</span><b>'+p.vol+'%</b></div>'+
      '<div class="phase__bar"><i style="width:'+p.vol+'%"></i></div>'+
      '<p class="phase__focus">'+getL(p.focus,lang)+'</p>'+
    '</div>';
  }).join('');
  // composition
  var sig = getL(m.signature,lang).map(function(s){ return '<span class="tag-mv">'+s+'</span>'; }).join('');
  var peakBadge = m.peakWeek
    ? '<span class="macro__peak">'+L(lang,'lbl_peakAt').replace('{w}', m.peakWeek)+'</span>'
    : '<span class="macro__peak flat">'+L(lang,'lbl_noPeak')+'</span>';

  host.innerHTML =
    '<div class="detail" style="--mc:'+m.color+'">'+
      '<div class="detail__hd">'+
        '<div><span class="detail__fam">'+m.family+'</span>'+
          '<h3>'+m.name+'</h3>'+
          '<p class="sub">'+getL(m.char,lang)+'</p></div>'+
        '<div style="text-align:right; white-space:nowrap;">'+peakBadge+
          '<div class="macro__meta" style="justify-content:flex-end; margin-top:10px;"><span><b>'+m.freqDays+' '+L(lang,'lbl_daysWk')+'</b></span><span><b>'+m.weeks+' '+L(lang,'lbl_weeksWord')+'</b></span></div>'+
        '</div>'+
      '</div>'+
      '<div class="detail__body">'+
        '<p class="map-cap">'+L(lang,'map_intensity')+(m.peakWeek?' <span class="pk">· ▲ '+L(lang,'lbl_peakFlag')+'</span>':'')+'</p>'+
        '<div class="imap">'+bars+'</div>'+
        '<div class="ribbon">'+ribbon+'</div>'+
        '<div class="phases">'+phaseCards+'</div>'+
        '<div class="compo">'+
          '<div class="compo__box"><p class="compo__t in">◆ '+L(lang,'lbl_signature')+'</p><div class="tags">'+sig+'</div></div>'+
          '<div class="compo__box compo__out"><p class="compo__t out">✕ '+L(lang,'lbl_leavesout')+'</p><p>'+getL(m.leavesOut,lang)+'</p></div>'+
        '</div>'+
      '</div>'+
    '</div>';
}
