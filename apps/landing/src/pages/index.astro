function patchReadiness(root,lang){
  var r=D.rdy;
  var big=root.querySelector('.l-big'); if(big) big.textContent=r;
  var sub=root.querySelector('.l-sub'); if(sub) sub.textContent=L(lang,rdyKey(r));
  var rv=root.querySelector('.rng-val'); if(rv) rv.textContent=r;
  var rows=root.querySelectorAll('.rxrow[data-ex]');
  for(var i=0;i<rows.length;i++){ var row=rows[i], rm=+row.getAttribute('data-rm'), p=+row.getAttribute('data-pct'), kg=workKg(rm,p,r), d=readyDelta(r);
    // El set de discos sólo cambia cuando cambia el kg; evitamos regenerar SVGs en cada tick del slider.
    if(String(kg)===row.getAttribute('data-lastkg')) continue;
    row.setAttribute('data-lastkg', kg);
    var kgEl=row.querySelector('.kg'); if(kgEl) kgEl.textContent=kg+' kg';
    var adj=row.querySelector('[data-adj]'); if(adj){ if(d<0){ adj.style.display=''; adj.textContent=fmtDelta(r); } else { adj.style.display='none'; } }
    var old=row.querySelector('.rxmeta .discs'); if(old){ var tmp=document.createElement('div'); tmp.innerHTML=discsInline(kg,26,lang); row.querySelector('.rxmeta').replaceChild(tmp.firstChild, old); }
    var exp=row.querySelector('.rx-expand'); if(exp && row.classList.contains('rxrow--open')){ exp.innerHTML=exExpandHtml(rm,p,r,lang); }
  }
}
function initDemo(){
  var root=document.getElementById('demoRoot'); if(!root) return;
  root.addEventListener('click', function(ev){
    var t=ev.target.closest ? ev.target.closest('[data-act]') : null; if(!t) return;
    var act=t.getAttribute('data-act'), lang=currentLang();
    if(act==='view'){ if(D.view!==t.getAttribute('data-v')){ D.view=t.getAttribute('data-v'); D.ex=null; D.athOpen=false; renderDemo(lang); } }
    else if(act==='school'){ D.sc=+t.getAttribute('data-i'); D.day=0; D.ex=null; renderDemo(lang); }
    else if(act==='day'){ D.day=+t.getAttribute('data-i'); D.ex=null; renderDemo(lang); }
    else if(act==='ex'){ var i=+t.getAttribute('data-ex'); D.ex=(D.ex===i?null:i); renderDemo(lang); }
    else if(act==='ath'){ D.ath=+t.getAttribute('data-i'); D.athOpen=true; D.ex=null; renderDemo(lang); }
    else if(act==='back'){ D.athOpen=false; renderDemo(lang); }
  });
  root.addEventListener('input', function(ev){
    var t=ev.target; if(t && t.getAttribute && t.getAttribute('data-act')==='rdy'){ D.rdy=+t.value; patchReadiness(root, currentLang()); }
  });
  // Las filas expandibles son <div role="button">; los botones nativos ya manejan Enter/Espacio.
  root.addEventListener('keydown', function(ev){
    if(ev.key!=='Enter' && ev.key!==' ' && ev.key!=='Spacebar') return;
    var t=ev.target; if(t && t.classList && t.classList.contains('rxrow--ex')){ ev.preventDefault(); t.click(); }
  });
}

