  .coach.has-sel .coach__detail{ display:block; }
  .coach-back{ display:inline-flex; align-items:center; gap:7px; font-family:var(--mono); font-size:12px; color:var(--gold); background:none; border:none; cursor:pointer; padding:0; margin-bottom:12px; }
}

/* ===== Differentials ===== */
.diffs{ display:flex; flex-wrap:wrap; gap:12px; }
.chip{ display:inline-flex; align-items:center; gap:9px; border:1px solid var(--hair); border-radius:12px; padding:12px 16px; background:var(--surface); font-size:14.5px; font-weight:600; }
.chip .dot{ color:var(--teal); font-size:15px; }

/* ===== Final CTA ===== */
.final{ position:relative; overflow:hidden; }
.final .panel{
  position:relative; border:1px solid rgba(233,196,106,.25); border-radius:26px; padding:clamp(34px,6vw,64px);
  text-align:center; background:radial-gradient(110% 130% at 50% 0%, rgba(233,196,106,.1), transparent 55%), var(--surface);
  overflow:hidden;
}
.final .panel::after{
  content:""; position:absolute; left:50%; bottom:-46%; width:560px; height:560px; transform:translateX(-50%);
  background:radial-gradient(circle, rgba(216,38,45,.18), transparent 62%); pointer-events:none;
}
.final h2{ font-size:clamp(28px,4.4vw,46px); }
.final .section-lead{ margin-left:auto; margin-right:auto; }
.final .cta-row{ justify-content:center; }
.final .cta-note{ justify-content:center; }

/* ===== Footer ===== */
footer{ border-top:1px solid var(--hair); padding:32px 0; }
.foot{ display:flex; flex-wrap:wrap; align-items:center; gap:14px; justify-content:space-between; }
.foot .left{ display:flex; align-items:center; gap:10px; }
.foot .mark{ width:28px; height:28px; }
.foot p{ margin:0; color:var(--muted); font-size:13px; }
.foot a.mail{ color:var(--gold); font-family:var(--mono); font-size:13px; }

/* ===== Macro catalog ===== */
.macros{ display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }
.macro{
  position:relative; text-align:left; cursor:pointer; border:1px solid var(--hair); border-radius:18px; padding:20px;
  background:var(--surface); color:inherit; overflow:hidden; transition:transform .2s var(--ease-out), border-color .2s, box-shadow .2s;
}
.macro::before{ content:""; position:absolute; left:0; top:0; bottom:0; width:4px; background:var(--mc,#888); }
.macro:hover{ transform:translateY(-4px); box-shadow:0 22px 44px -28px rgba(0,0,0,.8); }
.macro.sel{ border-color:var(--mc); box-shadow:0 0 0 1px var(--mc) inset, 0 22px 44px -28px rgba(0,0,0,.8); }
.macro__top{ display:flex; align-items:center; justify-content:space-between; gap:10px; }
.macro__fam{ font-family:var(--mono); font-size:10.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--mc,#9aa3ad); font-weight:700; }
.macro__peak{ font-family:var(--mono); font-size:10px; padding:3px 8px; border-radius:999px; background:rgba(233,196,106,.14); color:var(--gold); border:1px solid rgba(233,196,106,.3); }
.macro__peak.flat{ background:rgba(255,255,255,.05); color:var(--muted); border-color:var(--hair); }
.macro__name{ font-family:var(--display); font-weight:800; font-size:21px; margin:10px 0 6px; letter-spacing:-.01em; }
.macro__desc{ color:var(--muted); font-size:13px; margin:0 0 14px; min-height:34px; }
.macro__meta{ display:flex; gap:14px; flex-wrap:wrap; font-family:var(--mono); font-size:11px; color:#aab2bc; }
.macro__meta b{ color:var(--text); }
.meters{ display:flex; gap:16px; margin-top:14px; }
.meter{ flex:1; }
.meter span{ font-family:var(--mono); font-size:10px; color:var(--muted); letter-spacing:.06em; text-transform:uppercase; }
.dots{ display:flex; gap:3px; margin-top:5px; }
.dots i{ flex:1; height:5px; border-radius:3px; background:rgba(255,255,255,.1); }
.dots i.on{ background:var(--mc,var(--gold)); }
.macro__open{ position:absolute; right:16px; bottom:14px; font-family:var(--mono); font-size:10.5px; color:var(--mc); opacity:.85; }

/* ===== Macro detail ===== */
.detail{ border:1px solid var(--hair); border-radius:22px; overflow:hidden; background:var(--surface); }
.detail__hd{ padding:22px 24px; border-bottom:1px solid var(--hair); display:flex; align-items:flex-start; justify-content:space-between; gap:16px; background:linear-gradient(90deg, color-mix(in srgb, var(--mc) 12%, transparent), transparent 60%); }
.detail__hd h3{ font-family:var(--display); font-weight:800; font-size:clamp(22px,3vw,30px); margin:0; letter-spacing:-.01em; }
.detail__hd .sub{ color:#aab2bc; font-size:14px; margin:8px 0 0; max-width:60ch; }
.detail__fam{ font-family:var(--mono); font-size:11px; letter-spacing:.1em; text-transform:uppercase; color:var(--mc); font-weight:700; }
.detail__body{ padding:24px; }
.map-cap{ font-family:var(--mono); font-size:11px; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); margin:0 0 14px; display:flex; align-items:center; gap:10px; }
.map-cap .pk{ color:var(--gold); }
/* intensity bars */
.imap{ display:flex; align-items:flex-end; gap:3px; height:130px; padding:14px 0 0; }
.imap .col{ position:relative; flex:1; display:flex; flex-direction:column; justify-content:flex-end; align-items:center; height:100%; }
.imap .bar{ width:100%; border-radius:3px 3px 0 0; background:var(--bc); min-height:6px; transition:height .5s var(--ease-out); }
.imap .col.peak .bar{ background:linear-gradient(180deg,#F8E7AE,#E9C46A); box-shadow:0 0 14px rgba(233,196,106,.6); }
.imap .col .flag{ position:absolute; top:-16px; font-size:11px; color:var(--gold); }
.imap .wk{ font-family:var(--mono); font-size:8px; color:var(--muted); margin-top:5px; }
/* phase ribbon */
.ribbon{ display:flex; gap:3px; margin-top:8px; }
.ribbon .seg{ height:8px; border-radius:3px; background:var(--bc); }
/* phase cards */
.phases{ display:grid; grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); gap:12px; margin-top:24px; }
.phase{ border:1px solid var(--hair); border-radius:14px; padding:15px; background:var(--surface-2); border-top:3px solid var(--bc); }
.phase__wk{ font-family:var(--mono); font-size:10.5px; color:var(--muted); letter-spacing:.05em; }
.phase__nm{ font-family:var(--cond); font-weight:800; font-size:17px; text-transform:uppercase; letter-spacing:.02em; margin:4px 0 10px; }
.phase__row{ display:flex; justify-content:space-between; font-family:var(--mono); font-size:11.5px; margin-top:5px; }
.phase__row span{ color:var(--muted); } .phase__row b{ color:var(--text); }
.phase__bar{ height:5px; border-radius:3px; background:rgba(255,255,255,.1); margin-top:4px; overflow:hidden; }
.phase__bar i{ display:block; height:100%; background:var(--bc); }
.phase__focus{ color:#9aa3ad; font-size:12px; margin:10px 0 0; line-height:1.4; }
/* composition */
.compo{ display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-top:24px; }
.compo__box{ border:1px solid var(--hair); border-radius:14px; padding:16px; background:var(--surface-2); }
.compo__t{ font-family:var(--mono); font-size:10.5px; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); margin:0 0 10px; }
.compo__t.in{ color:var(--teal); } .compo__t.out{ color:var(--danger); }
.tags{ display:flex; flex-wrap:wrap; gap:7px; }
.tag-mv{ font-size:13px; font-weight:600; padding:6px 11px; border-radius:9px; background:rgba(46,230,160,.08); border:1px solid rgba(46,230,160,.2); }
.compo__out p{ margin:0; color:#aab2bc; font-size:13.5px; line-height:1.45; }

/* ===== Responsive ===== */
@media (max-width:860px){
  .macros{ grid-template-columns:1fr; }
  .compo{ grid-template-columns:1fr; }
  .imap{ height:110px; }
  .imap .wk{ display:none; }
  .detail__hd{ flex-direction:column; }
  .hero .wrap{ grid-template-columns:1fr; }
  .hero-art{ order:-1; }
  .hero-art .disc-icon{ width:min(70%,300px); }
  .pains{ grid-template-columns:1fr; }
  .bento{ grid-template-columns:1fr; }
  .shots{ grid-template-columns:1fr; }
}
@media (max-width:560px){
