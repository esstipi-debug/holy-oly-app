function mvName(mv,lang){ return getL(MV[mv],lang); }
function readyDelta(r){ return r>=85 ? 0 : r>=75 ? -2.5 : -5; }
function workKg(rm,p,r){ return Math.max(20, Math.round(rm*(p+readyDelta(r))/100)); }
function rdyKey(r){ return r>=90 ? 'ready_hi' : r>=80 ? 'ready_mid' : r>=72 ? 'ready_lo' : 'ready_min'; }
function rdyColor(r){ return r>=85 ? '#1bc98a' : r>=72 ? '#E9C46A' : '#ff3b46'; }
function fmtDelta(r){ var d=readyDelta(r); return d<0 ? '−'+Math.abs(d)+'%' : ''; }
function discsInline(kg,size,lang){
  var ds=perSide(kg,20), inner='';
  for(var i=0;i<ds.length;i++){ inner+=disc3q(ds[i],size); }
  return '<span class="discs"><span class="lbl">'+L(lang,'per_side')+'</span>'+inner+'</span>';
}
function exExpandHtml(rm,p,r,lang){
  var kg=workKg(rm,p,r), fr=[0.5,0.7,0.85], lad='';
  for(var i=0;i<fr.length;i++){ var k=Math.max(20,Math.round(kg*fr[i])); lad+='<span class="step">'+Math.round(fr[i]*100)+'% · <b>'+k+'</b></span>'; }
  lad+='<span class="step work">'+L(lang,'ramp_work')+' · <b>'+kg+' kg</b></span>';
  var note=readyDelta(r)<0 ? '<div class="rx-note">'+L(lang,'rx_adjnote')+'</div>' : '';
  return '<div class="rx-expand__in"><div class="ramp">'+lad+'</div><div class="rx-bigdiscs">'+discsInline(kg,44,lang)+'</div>'+note+'</div>';
}
function exRowHtml(ex,i,rm,r,lang){
  var kg=workKg(rm,ex.p,r), d=readyDelta(r), open=(D.ex===i);
  return '<div class="rxrow rxrow--ex'+(open?' rxrow--open':'')+'" data-act="ex" data-ex="'+i+'" data-rm="'+rm+'" data-pct="'+ex.p+'" data-lastkg="'+kg+'" tabindex="0" role="button" aria-expanded="'+(open?'true':'false')+'">'+
    '<div class="rxtop"><span class="rxname">'+mvName(ex.mv,lang)+'</span>'+
      '<span class="rxsets">'+ex.s+' × '+ex.r+'<span class="rxchev">›</span></span></div>'+
    '<div class="rxmeta"><span class="badge-int">'+ex.p+'%</span>'+
      '<span class="kg">'+kg+' kg</span>'+
      '<span class="adj" data-adj'+(d<0?'':' style="display:none"')+'>'+fmtDelta(r)+'</span>'+
      discsInline(kg,26,lang)+'</div>'+
    '<div class="rx-expand">'+(open?exExpandHtml(rm,ex.p,r,lang):'')+'</div>'+
  '</div>';
}
function planHtml(sch,dayIdx,r,scale,lang){
  var day=sch.days[dayIdx];
  var rows='<div class="rxrow rxrow--warm"><div class="rxtop"><span class="rxname">'+L(lang,'ex_warmup')+'</span><span class="warm-tag">'+L(lang,'warm_tag')+'</span></div>'+
    '<div class="rxmeta"><span class="warm-ramp">40% <i>›</i> 55% <i>›</i> 70%</span><span class="rxsets" style="margin-left:auto;">'+L(lang,'warm_sub')+'</span></div></div>';
  for(var i=0;i<day.ex.length;i++){ var ex=day.ex[i]; rows+=exRowHtml(ex,i,Math.round((RM[ex.mv]||100)*scale),r,lang); }
  return '<div class="shot__hd"><span class="shot__title">'+L(lang,'today_word')+' · '+getL(day.f,lang)+'</span>'+
    '<span class="shot__tag">'+L(lang,'phase_word')+': '+getL(day.ph,lang)+'</span></div><div class="rx">'+rows+'</div>';
}
function readyCardHtml(r,lang){
