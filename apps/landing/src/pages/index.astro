.coach__detail{ border:1px solid var(--hair); border-radius:16px; background:var(--surface-2); padding:16px; }
.coach-back{ display:none; }
@media (max-width:860px){
  .demo__cols{ grid-template-columns:1fr; }
  .appwin{ max-width:392px; margin:0 auto; background:#0c0f13; border:1px solid var(--hair); border-radius:40px; padding:12px 12px 20px; box-shadow:0 0 0 9px #15181e, 0 30px 70px -22px #000; }
  .appwin__bar{ display:flex; align-items:center; justify-content:center; height:24px; margin-bottom:8px; }
  .appwin__bar::before{ content:""; width:118px; height:7px; border-radius:999px; background:#000; }
  .coach{ grid-template-columns:1fr; }
