function renderDemo(lang){
  var root=document.getElementById('demoRoot'); if(!root) return;
  lang=lang||currentLang();
  var seg='<div class="demo__seg" role="tablist">'+
    '<button type="button" role="tab" aria-selected="'+(D.view==='atleta')+'" data-act="view" data-v="atleta" class="'+(D.view==='atleta'?'on':'')+'">'+L(lang,'seg_atleta')+'</button>'+
    '<button type="button" role="tab" aria-selected="'+(D.view==='coach')+'" data-act="view" data-v="coach" class="'+(D.view==='coach'?'on':'')+'">'+L(lang,'seg_coach')+'</button></div>';
  root.innerHTML='<div class="demo__toolbar">'+seg+'<span class="demo__hint"><i>•</i>'+L(lang,'demo_hint')+'</span></div>'+
    '<div class="demo__stage">'+(D.view==='coach'?coachHtml(lang):atletaHtml(lang))+'</div>';
