function phaseAt(m, w){
  for(var i=0;i<m.phases.length;i++){ var p=m.phases[i]; if(w>=p.weeks[0] && w<=p.weeks[1]) return i; }
  return 0;
}
function renderDetail(lang){
  var host = document.getElementById('macroDetail'); if(!host) return;
  var m = MACROS.filter(function(x){return x.id===currentMacroId;})[0] || MACROS[0];
  var n = m.phases.length;
  // intensity bars
  var bars='';
  for(var w=1; w<=m.weeks; w++){
    var pi = phaseAt(m,w), p=m.phases[pi];
    var mid=(p.pct[0]+p.pct[1])/2;
    var h = Math.max(12, Math.min(100, ((mid-55)/(105-55))*78 + 22));
    var isPeak = m.peakWeek===w;
    bars += '<div class="col'+(isPeak?' peak':'')+'" style="--bc:'+phaseColor(m.color,pi,n)+'">'+
      (isPeak?'<span class="flag">▲</span>':'')+
      '<div class="bar" style="height:'+h.toFixed(0)+'%"></div>'+
      '<div class="wk">'+w+'</div></div>';
  }
  // ribbon
  var ribbon = m.phases.map(function(p,i){
    var span=(p.weeks[1]-p.weeks[0]+1);
    return '<div class="seg" style="flex:'+span+';--bc:'+phaseColor(m.color,i,n)+'"></div>';
  }).join('');
  // phase cards
  var phaseCards = m.phases.map(function(p,i){
    var wk = p.weeks[0]===p.weeks[1] ? (L(lang,'lbl_weekShort')+' '+p.weeks[0]) : (L(lang,'lbl_weekShort')+' '+p.weeks[0]+'–'+p.weeks[1]);
