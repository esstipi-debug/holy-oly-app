/* ===== Lead capture (landing → API → registro de la app) ===== */
// POST /leads es público y SIN cookies (CORS abierto), así que la landing puede vivir en otro
// origen. Apunta estas dos constantes a tu API / app desplegada.
var LEAD_API = 'https://holy-oly.onrender.com';
var LEAD_REDIRECT_URL = 'https://holy-oly.onrender.com/login?mode=signup';

// LatAm primero (luego Australia —mercado prioritario— y otros orígenes comunes). Las etiquetas
// se localizan con Intl.DisplayNames; el value es el código ISO-3166 alpha-2 que se guarda crudo.
var COUNTRY_CODES = ['AR','CL','MX','CO','PE','UY','EC','BO','PY','VE','BR','US','ES','CR','GT','PA','DO','PR','HN','SV','NI','CU','AU','GB','CA','IT','FR','DE','PT'];

function renderCountries(lang){
  var sel = document.getElementById('leadCountry'); if(!sel) return;
  var dict = I18N[lang] || I18N.es;
  var prev = sel.value;
  var dn = null;
  try{ dn = new Intl.DisplayNames([lang==='pt'?'pt-BR':lang], {type:'region'}); }catch(e){}
  var html = '<option value="" disabled'+(prev?'':' selected')+'>'+(dict.cta_country_ph||'País…')+'</option>';
  COUNTRY_CODES.forEach(function(code){
    var name = dn ? (dn.of(code)||code) : code;
    html += '<option value="'+code+'">'+name+'</option>';
  });
  html += '<option value="ZZ">'+(dict.cta_country_other||'Otro')+'</option>';
  sel.innerHTML = html;
  if(prev){ sel.value = prev; }
}

function initLeadForm(){
  var form = document.getElementById('leadForm'); if(!form) return;
  form.addEventListener('submit', function(ev){
    ev.preventDefault();
    if(!form.reportValidity()) return;
    var btn = form.querySelector('button[type="submit"]');
    if(btn){ btn.disabled = true; }
    var payload = {
      email: (form.email.value||'').trim(),
      athletes: parseInt(form.athletes.value, 10),
      country: form.country.value,
      website: form.website.value
    };
    // Fire-and-redirect: keepalive deja que el POST termine durante la navegación; nunca atrapamos
    // al usuario si el API está lento o caído.
    var go = function(){ window.location.href = LEAD_REDIRECT_URL; };
    try{
      fetch(LEAD_API + '/leads', {
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify(payload),
        keepalive:true
      }).then(go, go);
    }catch(e){ go(); }
  });
}

function setLang(lang){
  var dict = I18N[lang] || I18N.es;
  document.documentElement.lang = (lang==='pt') ? 'pt-BR' : lang;
  document.querySelectorAll('[data-i18n]').forEach(function(el){
    var k = el.getAttribute('data-i18n');
    if(dict[k]==null) return;
    var attr = el.getAttribute('data-i18n-attr');
    if(attr){ el.setAttribute(attr, dict[k]); }
    else if(el.tagName==='TITLE'){ document.title = dict[k]; }
    else { el.innerHTML = dict[k]; }
  });
  document.querySelectorAll('.langsw button').forEach(function(b){
    b.classList.toggle('active', b.getAttribute('data-lang')===lang);
  });
  renderMacros(lang);
  renderDemo(lang);
  renderCountries(lang);
  try{ localStorage.setItem('holyoly-lang', lang); }catch(e){}
}

(function initLang(){
  var saved=null;
  try{ saved = localStorage.getItem('holyoly-lang'); }catch(e){}
  var nav = (navigator.language || navigator.userLanguage || 'es').toLowerCase();
  var auto = saved || (nav.indexOf('pt')===0 ? 'pt' : nav.indexOf('en')===0 ? 'en' : 'es');
  setLang(auto);
  fillDiscs();
  document.querySelectorAll('.langsw button').forEach(function(b){
    b.addEventListener('click', function(){ setLang(b.getAttribute('data-lang')); });
  });
  initLeadForm();
  initDemo();
})();

/* ===== Scroll reveal ===== */
(function(){
  var els = document.querySelectorAll('.rv');
  if(!('IntersectionObserver' in window)){ els.forEach(function(e){ e.classList.add('in'); }); return; }
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(en){ if(en.isIntersecting){ en.target.classList.add('in'); io.unobserve(en.target); } });
  }, { threshold:0.12, rootMargin:"0px 0px -8% 0px" });
  els.forEach(function(e){ io.observe(e); });
})();
</script>
