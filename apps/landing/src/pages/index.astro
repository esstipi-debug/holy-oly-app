---
// Port fiel de docs/marketing/landing-coach.html (fuente histórica, sin tocar) a Astro.
// Página standalone: define su propio documento completo (no usa Base.astro del blog),
// porque es un sistema visual propio (dark/gold) distinto del editorial del blog.
---

<!doctype html>
<html lang="es">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title data-i18n="meta_title">Holy Oly — Periodización para coaches de levantamiento</title>
<meta name="description" data-i18n-attr="content" data-i18n="meta_desc" content="Indica la fecha de la competencia y Holy Oly arma los ciclos para que tu atleta llegue en Peak. Periodización automática, carga y estrés de cada atleta, todo tu equipo en un panel." />
<meta name="theme-color" content="#0A0B0E" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Saira:wght@600;700;800;900&family=Saira+Condensed:wght@600;700;800&family=Space+Mono:wght@400;700&family=Archivo:wght@400;500;600;700&display=swap" rel="stylesheet" />
<style is:global>
:root{
  --bg:#0A0B0E; --surface:#11151A; --surface-2:#20262E; --hair:rgba(255,255,255,.08);
  --text:#EEF2F6; --muted:#6B7480; --gold:#E9C46A; --teal:#2EE6A0; --danger:#ff3b46;
  --display:'Saira',sans-serif; --cond:'Saira Condensed',sans-serif; --body:'Archivo',sans-serif; --mono:'Space Mono',ui-monospace,monospace;
  --maxw:1120px; --ease-out:cubic-bezier(.2,.7,.3,1); --ease-spring:cubic-bezier(.34,1.56,.64,1);
}
*{ box-sizing:border-box; }
html{ scroll-behavior:smooth; }
body{
  margin:0; background:var(--bg); color:var(--text); font-family:var(--body); line-height:1.55;
  -webkit-font-smoothing:antialiased; overflow-x:hidden;
}
a{ color:inherit; text-decoration:none; }
.wrap{ width:100%; max-width:var(--maxw); margin:0 auto; padding:0 clamp(18px,4vw,40px); }
.mono{ font-family:var(--mono); }
.gold{ color:var(--gold); }
.teal{ color:var(--teal); }
.grad{ background:linear-gradient(135deg,#F8E7AE,#E9C46A 45%,#C49A41); -webkit-background-clip:text; background-clip:text; color:transparent; }

/* ===== Header ===== */
header{
  position:sticky; top:0; z-index:50; backdrop-filter:blur(12px);
  background:rgba(10,11,14,.72); border-bottom:1px solid var(--hair);
}
.nav{ display:flex; align-items:center; gap:16px; height:64px; }
.brand{ display:flex; align-items:center; gap:10px; font-family:var(--display); font-weight:900; letter-spacing:.02em; font-size:18px; }
.brand .mark{ width:34px; height:34px; flex:0 0 34px; filter:drop-shadow(0 2px 6px rgba(216,38,45,.35)); }
.nav .spacer{ flex:1; }
.nav-link{ font-family:var(--mono); font-size:13px; font-weight:700; letter-spacing:.04em; color:var(--muted); transition:color .15s; }
.nav-link:hover{ color:var(--text); }
.langsw{ display:inline-flex; border:1px solid var(--hair); border-radius:999px; padding:3px; background:rgba(255,255,255,.03); }
.langsw button{
  font-family:var(--mono); font-size:11px; font-weight:700; letter-spacing:.06em; color:var(--muted);
  background:none; border:none; cursor:pointer; padding:5px 9px; border-radius:999px; transition:color .15s, background .15s;
}
.langsw button.active{ color:#1a1205; background:linear-gradient(180deg,#F8E7AE,#E9C46A); }
.btn{
  font-family:var(--display); font-weight:800; letter-spacing:.02em; cursor:pointer; border:none;
  display:inline-flex; align-items:center; justify-content:center; gap:8px; text-align:center;
  transition:transform .12s var(--ease-spring), box-shadow .2s, filter .2s;
}
.btn--primary{
  color:#1a1205; background:linear-gradient(180deg,#F8E7AE,#E9C46A 55%,#C49A41);
  border-radius:12px; padding:13px 22px; font-size:16px;
  box-shadow:0 1px 0 rgba(255,255,255,.5) inset, 0 10px 26px -8px rgba(233,196,106,.55);
}
.btn--primary:hover{ filter:brightness(1.05); transform:translateY(-1px); }
.btn--primary:active{ transform:scale(.97); }
.btn--sm{ padding:9px 16px; font-size:14px; border-radius:10px; }
.btn--ghost{
  color:var(--text); background:rgba(255,255,255,.05); border:1px solid var(--hair);
  border-radius:12px; padding:13px 22px; font-size:16px;
}
.btn--ghost:hover{ background:rgba(255,255,255,.09); }

/* ===== Reveal ===== */
.rv{ opacity:0; transform:translateY(22px); transition:opacity .7s var(--ease-out), transform .7s var(--ease-out); }
.rv.in{ opacity:1; transform:none; }
@media (prefers-reduced-motion:reduce){ .rv{ opacity:1; transform:none; transition:none; } html{ scroll-behavior:auto; } }

/* ===== Hero ===== */
.hero{ position:relative; padding:clamp(48px,9vw,104px) 0 clamp(40px,7vw,80px); overflow:hidden; }
.hero::before{
  content:""; position:absolute; inset:0; z-index:0; pointer-events:none;
  background:
    radial-gradient(60% 50% at 78% 18%, rgba(216,38,45,.16), transparent 60%),
    radial-gradient(50% 45% at 12% 8%, rgba(46,230,160,.08), transparent 60%);
}
.hero .wrap{ position:relative; z-index:1; display:grid; grid-template-columns:1.15fr .85fr; gap:clamp(24px,4vw,56px); align-items:center; }
.eyebrow{
  display:inline-flex; align-items:center; gap:8px; font-family:var(--mono); font-size:11.5px; font-weight:700;
  letter-spacing:.14em; text-transform:uppercase; color:var(--gold);
  border:1px solid rgba(233,196,106,.3); border-radius:999px; padding:6px 12px; background:rgba(233,196,106,.06);
}
.eyebrow i{ width:6px; height:6px; border-radius:50%; background:var(--teal); box-shadow:0 0 8px var(--teal); }
h1{
  font-family:var(--display); font-weight:900; letter-spacing:-.02em; line-height:1.02;
  font-size:clamp(34px,5.4vw,60px); margin:18px 0 0;
}
.lead{ color:#c3cad3; font-size:clamp(16px,1.6vw,19px); max-width:54ch; margin:18px 0 0; }
.cta-row{ display:flex; flex-wrap:wrap; gap:14px; align-items:center; margin-top:28px; }
.cta-note{ color:var(--muted); font-size:13px; margin-top:14px; display:flex; align-items:center; gap:8px; }
.cta-note b{ color:var(--teal); font-weight:700; }
.hero-art{ position:relative; display:flex; align-items:center; justify-content:center; }
.hero-art .disc-icon{ width:min(100%,420px); aspect-ratio:1; filter:drop-shadow(0 40px 80px -20px rgba(216,38,45,.5)); animation:floaty 7s ease-in-out infinite; }
@keyframes floaty{ 0%,100%{ transform:translateY(0) rotate(0); } 50%{ transform:translateY(-14px) rotate(-1.2deg); } }
@media (prefers-reduced-motion:reduce){ .hero-art .disc-icon{ animation:none; } }

/* ===== Section scaffolding ===== */
section{ padding:clamp(48px,8vw,92px) 0; position:relative; }
.kicker{ font-family:var(--mono); font-size:12px; font-weight:700; letter-spacing:.16em; text-transform:uppercase; color:var(--teal); }
h2{ font-family:var(--display); font-weight:800; letter-spacing:-.015em; line-height:1.06; font-size:clamp(26px,3.6vw,40px); margin:10px 0 0; }
.section-lead{ color:#aab2bc; font-size:clamp(15px,1.5vw,18px); max-width:60ch; margin:14px 0 0; }
.section-head{ margin-bottom:clamp(28px,4vw,48px); }

/* ===== Problem ===== */
.problem{ background:linear-gradient(180deg,transparent, rgba(255,255,255,.015)); }
.pains{ display:grid; grid-template-columns:repeat(3,1fr); gap:18px; }
.pain{ border:1px solid var(--hair); border-radius:16px; padding:24px; background:var(--surface); }
.pain .x{ width:34px; height:34px; border-radius:9px; display:flex; align-items:center; justify-content:center; font-size:18px; background:rgba(255,59,70,.12); color:var(--danger); border:1px solid rgba(255,59,70,.22); }
.pain h3{ font-family:var(--display); font-weight:800; font-size:19px; margin:16px 0 6px; }
.pain p{ color:var(--muted); font-size:14.5px; margin:0; }

/* ===== Pillars (bento) ===== */
.bento{ display:grid; grid-template-columns:repeat(3,1fr); gap:18px; }
.pillar{
  position:relative; border:1px solid var(--hair); border-radius:20px; padding:26px; overflow:hidden;
  background:radial-gradient(120% 90% at 0% 0%, rgba(255,255,255,.05), transparent 60%), var(--surface);
  transition:transform .25s var(--ease-out), border-color .25s, box-shadow .25s;
}
.pillar:hover{ transform:translateY(-4px); border-color:rgba(233,196,106,.35); box-shadow:0 24px 48px -28px rgba(0,0,0,.8); }
.pillar .ic{ width:46px; height:46px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:22px; background:rgba(233,196,106,.12); border:1px solid rgba(233,196,106,.25); }
.pillar h3{ font-family:var(--display); font-weight:800; font-size:21px; margin:18px 0 8px; letter-spacing:-.01em; }
.pillar p{ color:#aab2bc; font-size:15px; margin:0; }
.pillar p b{ color:var(--text); font-weight:700; }

/* ===== How it looks (mockups) ===== */
.shots{ display:grid; grid-template-columns:1.25fr 1fr; gap:18px; align-items:stretch; }
.shot{ border:1px solid var(--hair); border-radius:20px; background:var(--surface); padding:20px; }
.shot--side{ display:grid; gap:18px; }
.shot__hd{ display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; }
.shot__title{ font-family:var(--cond); font-weight:800; font-size:18px; text-transform:uppercase; letter-spacing:.04em; }
.shot__tag{ font-family:var(--mono); font-size:10.5px; color:var(--muted); letter-spacing:.06em; }
/* prescription rows */
.rx{ display:grid; gap:10px; }
.rxrow{ border:1px solid var(--hair); border-radius:13px; padding:13px 14px; background:var(--surface-2); }
.rxtop{ display:flex; align-items:baseline; justify-content:space-between; gap:10px; }
.rxname{ font-family:var(--cond); font-weight:700; font-size:17px; letter-spacing:.02em; }
.rxsets{ font-family:var(--mono); font-size:12.5px; color:#cfd5dc; }
.rxmeta{ display:flex; align-items:center; gap:10px; margin-top:10px; flex-wrap:wrap; }
.badge-int{ font-family:var(--mono); font-weight:700; font-size:12px; color:#1a1205; background:linear-gradient(180deg,#ffd34d,#e6a912); border-radius:7px; padding:4px 9px; box-shadow:0 2px 6px rgba(230,169,18,.3); }
.kg{ font-family:var(--mono); font-weight:700; font-size:14px; color:var(--text); }
.discs{ display:flex; align-items:center; gap:6px; margin-left:auto; }
.discs .lbl{ font-family:var(--mono); font-size:10px; color:var(--muted); margin-right:2px; }
.discs svg{ display:block; filter:drop-shadow(0 2px 4px rgba(0,0,0,.45)); }
.rxrow--warm{ background:linear-gradient(180deg, rgba(46,230,160,.07), rgba(46,230,160,.02)); border-color:rgba(46,230,160,.28); }
.warm-tag{ font-family:var(--mono); font-size:10px; font-weight:700; letter-spacing:.08em; color:var(--teal); background:rgba(46,230,160,.12); border:1px solid rgba(46,230,160,.3); border-radius:999px; padding:3px 9px; }
.warm-ramp{ display:flex; align-items:center; gap:8px; flex-wrap:wrap; font-family:var(--mono); font-weight:700; font-size:13px; color:#cfd5dc; }
.warm-ramp i{ color:var(--teal); font-style:normal; }
.signup{ display:flex; flex-direction:column; gap:11px; max-width:420px; margin:28px auto 0; text-align:left; }
.signup__field{ width:100%; font-family:var(--body); font-size:15px; color:var(--text); background:var(--surface-2); border:1px solid var(--hair); border-radius:12px; padding:13px 16px; outline:none; transition:border-color .18s, box-shadow .18s; }
.signup__field::placeholder{ color:var(--muted); }
.signup__field:focus{ border-color:var(--teal); box-shadow:0 0 0 3px rgba(46,230,160,.15); }
.signup__select{ appearance:none; -webkit-appearance:none; cursor:pointer; padding-right:40px; background-image:url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8' fill='none'><path d='M1 1l5 5 5-5' stroke='%236B7480' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'/></svg>"); background-repeat:no-repeat; background-position:right 14px center; }
.signup__select:invalid{ color:var(--muted); }
.signup .btn--primary{ width:100%; margin-top:3px; }
.signup__hp{ position:absolute!important; left:-9999px!important; width:1px!important; height:1px!important; opacity:0!important; pointer-events:none; }
/* readiness gold card */
.ready{ position:relative; border-radius:18px; overflow:hidden; padding:18px; color:#241A04; min-height:148px; box-shadow:0 18px 40px -16px rgba(233,196,106,.5), inset 0 0 0 1px rgba(255,240,200,.5); background:#C7A14C; }
.ready .l-base{ position:absolute; inset:0; background:linear-gradient(135deg,#6E561F 0%,#C7A14C 24%,#F8E7AE 47%,#C49A41 66%,#8A6E2C 100%); }
.ready .l-holo{ position:absolute; inset:0; mix-blend-mode:overlay; background:linear-gradient(115deg,transparent 30%,rgba(255,120,180,.28) 44%,rgba(120,200,255,.28) 52%,rgba(180,255,170,.24) 60%,transparent 72%); }
.ready .l-shine{ position:absolute; inset:0; background:radial-gradient(120% 80% at 80% -10%,rgba(255,255,255,.55),transparent 50%); }
.ready .l-in{ position:relative; }
.ready .l-eyebrow{ font-family:var(--mono); font-size:9.5px; font-weight:700; letter-spacing:1px; padding:4px 9px; border-radius:999px; background:rgba(36,26,4,.16); display:inline-block; }
.ready .l-big{ font-family:var(--display); font-weight:900; font-size:66px; line-height:.85; letter-spacing:-2px; margin-top:14px; }
.ready .l-sub{ font-family:var(--cond); font-weight:700; text-transform:uppercase; letter-spacing:.05em; font-size:13px; margin-top:6px; opacity:.85; }
/* heatmap */
.heat{ display:grid; grid-template-columns:repeat(10,1fr); gap:5px; }
.heat i{ aspect-ratio:1; border-radius:4px; background:rgba(255,255,255,.05); }
.heat i.h1{ background:#13412c; } .heat i.h2{ background:#1b6e46; } .heat i.h3{ background:#1bc98a; }
.heat i.hw{ background:#7a5410; } .heat i.ha{ background:#7a1f25; }
.heat-legend{ display:flex; align-items:center; gap:8px; margin-top:12px; font-family:var(--mono); font-size:10px; color:var(--muted); }
.heat-legend i{ width:11px; height:11px; border-radius:3px; display:inline-block; }

/* ===== Interactive app demo (atleta ⇄ coach) ===== */
.demo{ border:1px solid var(--hair); border-radius:22px; background:var(--surface); padding:clamp(14px,2.4vw,22px); }
.demo__toolbar{ display:flex; align-items:center; gap:14px; flex-wrap:wrap; margin-bottom:18px; }
.demo__seg{ display:inline-flex; background:var(--surface-2); border:1px solid var(--hair); border-radius:12px; padding:4px; gap:4px; }
.demo__seg button{ font-family:var(--cond); font-weight:800; text-transform:uppercase; letter-spacing:.04em; font-size:13.5px; color:var(--muted); background:none; border:none; cursor:pointer; padding:8px 18px; border-radius:9px; transition:color .15s, background .15s; }
.demo__seg button.on{ color:#1a1205; background:linear-gradient(180deg,#F8E7AE,#E9C46A); box-shadow:0 2px 8px -2px rgba(233,196,106,.5); }
.demo__hint{ font-family:var(--mono); font-size:11px; color:var(--muted); letter-spacing:.04em; margin-left:auto; display:inline-flex; align-items:center; gap:7px; }
.demo__hint i{ width:6px; height:6px; border-radius:50%; background:var(--teal); box-shadow:0 0 8px var(--teal); font-style:normal; }
.demo__schools{ display:flex; gap:8px; flex-wrap:wrap; margin-bottom:16px; }
.dchip{ font-family:var(--cond); font-weight:700; font-size:14px; letter-spacing:.02em; color:#cfd5dc; background:var(--surface-2); border:1px solid var(--hair); border-radius:999px; padding:7px 14px; cursor:pointer; transition:color .15s, border-color .15s; display:inline-flex; align-items:center; gap:8px; }
.dchip .swatch{ width:9px; height:9px; border-radius:50%; background:var(--dc,#888); }
.dchip:hover{ color:var(--text); border-color:rgba(255,255,255,.2); }
.dchip.on{ color:var(--text); border-color:var(--dc); box-shadow:0 0 0 1px var(--dc) inset; }
.appwin{ position:relative; }
.appwin__bar{ display:none; }
.demo__cols{ display:grid; grid-template-columns:1.25fr .85fr; gap:18px; align-items:start; }
.col-plan, .col-side{ display:grid; gap:16px; align-content:start; }
.daytabs{ display:flex; gap:6px; }
.daytab{ flex:1; font-family:var(--mono); font-weight:700; font-size:11.5px; letter-spacing:.03em; color:var(--muted); background:var(--surface-2); border:1px solid var(--hair); border-radius:10px; padding:8px 6px; cursor:pointer; text-align:center; transition:color .15s, border-color .15s, background .15s; }
.daytab.on{ color:var(--text); border-color:rgba(233,196,106,.4); background:rgba(233,196,106,.08); }
.daytab small{ display:block; font-size:9.5px; font-weight:400; color:var(--muted); margin-top:3px; text-transform:uppercase; letter-spacing:.04em; }
.daytab.on small{ color:#cfd5dc; }
.rxrow--ex{ cursor:pointer; transition:border-color .18s, background .18s; }
.rxrow--ex:hover{ border-color:rgba(233,196,106,.3); }
.rxrow--open{ border-color:rgba(233,196,106,.45); background:linear-gradient(180deg, rgba(233,196,106,.06), var(--surface-2)); }
.rxchev{ color:var(--muted); margin-left:7px; transition:transform .2s, color .2s; display:inline-block; }
.rxrow--open .rxchev{ transform:rotate(90deg); color:var(--gold); }
.rx-expand{ overflow:hidden; max-height:0; transition:max-height .3s var(--ease-out); }
.rxrow--open .rx-expand{ max-height:340px; }
.rx-expand__in{ padding-top:13px; margin-top:12px; border-top:1px dashed var(--hair); }
.ramp{ display:flex; flex-wrap:wrap; gap:7px; }
.ramp .step{ font-family:var(--mono); font-size:11.5px; color:#cfd5dc; background:var(--surface); border:1px solid var(--hair); border-radius:8px; padding:5px 9px; }
.ramp .step b{ color:var(--text); }
.ramp .step.work{ color:#1a1205; background:linear-gradient(180deg,#ffd34d,#e6a912); border:none; font-weight:700; }
.rx-bigdiscs{ display:flex; align-items:center; gap:6px; margin-top:12px; }
.rx-note{ font-family:var(--mono); font-size:10.5px; color:var(--muted); margin-top:10px; line-height:1.4; }
.adj{ font-family:var(--mono); font-weight:700; font-size:10.5px; color:#ffb4b9; background:rgba(255,59,70,.12); border:1px solid rgba(255,59,70,.25); border-radius:6px; padding:3px 7px; }
.ready-ctrl{ border:1px solid var(--hair); border-radius:14px; padding:14px 16px; background:var(--surface-2); }
.ready-ctrl__top{ display:flex; align-items:center; justify-content:space-between; font-family:var(--mono); font-size:11px; color:var(--muted); letter-spacing:.06em; text-transform:uppercase; margin-bottom:11px; }
.ready-ctrl__top .rng-val{ font-family:var(--display); font-weight:900; font-size:16px; color:var(--gold); }
.rng{ -webkit-appearance:none; appearance:none; width:100%; height:6px; border-radius:999px; background:linear-gradient(90deg,#7a1f25,#7a5410 55%,#1bc98a); outline:none; }
.rng::-webkit-slider-thumb{ -webkit-appearance:none; appearance:none; width:22px; height:22px; border-radius:50%; background:linear-gradient(180deg,#F8E7AE,#C49A41); border:2px solid #1a1205; cursor:pointer; box-shadow:0 2px 8px rgba(0,0,0,.5); }
.rng::-moz-range-thumb{ width:20px; height:20px; border-radius:50%; background:linear-gradient(180deg,#F8E7AE,#C49A41); border:2px solid #1a1205; cursor:pointer; }
.ready-ctrl__hint{ font-family:var(--mono); font-size:10.5px; color:var(--muted); margin-top:10px; line-height:1.4; }
.coach{ display:grid; grid-template-columns:1fr 1.05fr; gap:18px; align-items:start; }
.coach__roster{ display:grid; gap:9px; align-content:start; }
.rostitle{ font-family:var(--mono); font-size:11px; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); margin:0 0 3px; }
.rosrow{ display:grid; grid-template-columns:auto 1fr auto; align-items:center; gap:12px; border:1px solid var(--hair); border-radius:13px; padding:12px 13px; background:var(--surface-2); cursor:pointer; text-align:left; width:100%; font:inherit; color:inherit; transition:border-color .15s, background .15s; }
.rosrow:hover{ border-color:rgba(255,255,255,.2); }
.rosrow.on{ border-color:var(--gold); box-shadow:0 0 0 1px rgba(233,196,106,.5) inset; }
.rdy-pill{ font-family:var(--display); font-weight:900; font-size:18px; width:46px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; color:#0c0d0f; }
.ros-mid{ display:grid; gap:6px; min-width:0; }
.ros-name{ font-family:var(--cond); font-weight:800; font-size:16px; letter-spacing:.02em; }
.ros-sub{ font-family:var(--mono); font-size:11px; color:var(--muted); }
.ros-heat{ display:grid; grid-template-columns:repeat(10,1fr); gap:3px; width:120px; max-width:55vw; }
.ros-heat i{ aspect-ratio:1; border-radius:2px; }
.ros-alert{ font-family:var(--mono); font-size:10.5px; font-weight:700; letter-spacing:.02em; padding:4px 8px; border-radius:7px; text-align:center; }
.ros-alert.warn{ color:#ffd9a3; background:rgba(233,196,106,.12); border:1px solid rgba(233,196,106,.3); }
.ros-alert.bad{ color:#ffb4b9; background:rgba(255,59,70,.12); border:1px solid rgba(255,59,70,.28); }
