var DISC_COLORS = { 10:["#3eb24a","#2c8a37","#7fd07f"], 15:["#f3c200","#c79c00","#ffe46b"], 20:["#2f6fa8","#1d4f7e","#6fa3cf"], 25:["#d5232b","#a4161d","#ec6b6f"] };
var RIM_DARK = { 10:"#1c5c24", 15:"#8a6c00", 20:"#12365a", 25:"#6e0f14" };
var DISCS_ORDER = [25,20,15,10];
var DT = "translate(256 268) rotate(-5) scale(0.82 0.985) translate(-256 -268)";
var discUid = 0;
function perSide(total, bar){
  bar = bar || 20;
  var r = (total - bar) / 2, out = [];
  if(r < 5) return out;
  for(var i=0;i<DISCS_ORDER.length;i++){ var p=DISCS_ORDER[i]; while(r>=p){ out.push(p); r-=p; } }
  return out;
}
function disc3q(w, size){
  var c = DISC_COLORS[w], fill=c[0], edge=c[1], light=c[2], uid="d"+(discUid++);
  return '<svg viewBox="34 66 410 410" width="'+size+'" height="'+size+'" xmlns="http://www.w3.org/2000/svg">'+
    '<defs>'+
      '<radialGradient id="b'+uid+'" cx="40%" cy="33%" r="80%"><stop offset="0" stop-color="'+light+'"/><stop offset="50%" stop-color="'+fill+'"/><stop offset="100%" stop-color="'+edge+'"/></radialGradient>'+
      '<linearGradient id="r'+uid+'" x1="0" y1="1" x2="1" y2="0"><stop offset="0" stop-color="'+RIM_DARK[w]+'"/><stop offset="55%" stop-color="'+edge+'"/><stop offset="100%" stop-color="'+fill+'"/></linearGradient>'+
      '<radialGradient id="s'+uid+'" cx="38%" cy="32%" r="84%"><stop offset="0" stop-color="#ffffff"/><stop offset="45%" stop-color="#dadde0"/><stop offset="100%" stop-color="#9da1a6"/></radialGradient>'+
      '<radialGradient id="o'+uid+'" cx="42%" cy="36%" r="80%"><stop offset="0" stop-color="#8c9096"/><stop offset="100%" stop-color="#303236"/></radialGradient>'+
    '</defs>'+
    '<g transform="translate(-34 7)"><g transform="'+DT+'"><circle cx="256" cy="268" r="192" fill="url(#r'+uid+')"/></g></g>'+
    '<g transform="translate(-35 7)"><g transform="'+DT+'"><circle cx="256" cy="268" r="192" fill="none" stroke="rgba(255,255,255,.14)" stroke-width="3"/></g></g>'+
    '<g transform="'+DT+'">'+
      '<circle cx="256" cy="268" r="192" fill="none" stroke="rgba(0,0,0,.22)" stroke-width="2"/>'+
      '<circle cx="256" cy="268" r="192" fill="'+edge+'"/>'+
      '<circle cx="256" cy="268" r="186" fill="url(#b'+uid+')"/>'+
      '<circle cx="256" cy="268" r="186" fill="none" stroke="rgba(255,255,255,.12)" stroke-width="3"/>'+
      '<circle cx="256" cy="268" r="100" fill="none" stroke="rgba(0,0,0,.18)" stroke-width="3"/>'+
      '<circle cx="256" cy="268" r="96" fill="url(#s'+uid+')" stroke="rgba(0,0,0,.16)" stroke-width="1.5"/>'+
      '<circle cx="256" cy="268" r="88" fill="none" stroke="rgba(0,0,0,.10)" stroke-width="1.5"/>'+
      '<circle cx="256" cy="268" r="30" fill="url(#o'+uid+')"/>'+
      '<circle cx="256" cy="268" r="30" fill="none" stroke="rgba(255,255,255,.3)" stroke-width="2"/>'+
      '<text x="256" y="158" text-anchor="middle" font-size="100" font-weight="800" fill="#fff" font-family="Saira Condensed, sans-serif">'+w+'</text>'+
    '</g></svg>';
}
function fillDiscs(){
  document.querySelectorAll('.discs[data-kg]').forEach(function(el){
    if(el.getAttribute('data-filled')) return;
    var kg = +el.getAttribute('data-kg'), bar = +(el.getAttribute('data-bar')||20);
    var html = perSide(kg, bar).map(function(d){ return disc3q(d, 30); }).join('');
    el.insertAdjacentHTML('beforeend', html);
    el.setAttribute('data-filled','1');
  });
}

